          "name": "login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Obtener el cuerpo de la respuesta como texto\r",
                  "const responseBody = pm.response.text();\r",
                  "// Aplicar el Regex\r",
                  "const match = responseBody.match(/\"token\"\\s*:\\s*\"([^\"]+)\"/);\r",
                  "if (match && match[1]) {\r",
                  "    const token = match[1];\r",
                  "    pm.environment.set(\"tokennotas\", token);\r",
                  "    console.log(\"Token extraído con Regex:\", token);\r",
                  "}"
                ],
